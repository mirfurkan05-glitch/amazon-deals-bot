# Copy this file to .env for local testing (never commit the real .env).
# In production (GitHub Actions) these are set as repo Secrets/Variables instead —
# see README.md.

# From @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenGoesHere

# Your channel's @username (must be public) or numeric chat id (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel

# Your Amazon Associates tracking ID, e.g. yourname-20
AMAZON_ASSOCIATE_TAG=yourtag-20

# Which Amazon marketplace to scrape
AMAZON_DOMAIN=amazon.com

# How many new deals to post per run
MAX_DEALS_PER_RUN=5

# Skip deals below this discount percentage (0 = post everything found)
MIN_DISCOUNT_PERCENT=20

# Set to true to preview what would be posted without sending to Telegram
# or writing to data/posted_deals.json
DRY_RUN=true
